# DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/onceuponus

# Redis
REDIS_URL=redis://localhost:6379

# AI APIs - 무료 티어 ✅
GEMINI_API_KEY=          # https://aistudio.google.com (무료)
HF_TOKEN=                # https://huggingface.co/settings/tokens (무료)
ELEVENLABS_API_KEY=      # https://elevenlabs.io (무료 10,000자/월)

# AI APIs - 유료 (Phase 2 고품질 전환용)
ANTHROPIC_API_KEY=
FAL_KEY=
SOUNDRAW_API_KEY=

# AWS S3 (데모에서는 로컬 파일시스템 사용 - 불필요)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=onceuponus-videos

# 로컬 파일 저장 경로 (기본값: /tmp/onceuponus)
LOCAL_STORAGE_DIR=/tmp/onceuponus

# Auth
NEXTAUTH_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# App
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000
