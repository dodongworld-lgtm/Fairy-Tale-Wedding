# DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/onceuponus

# Redis
REDIS_URL=redis://localhost:6379

# Gemini API (이미지 + 스토리 + TTS + BGM 통합)
GEMINI_API_KEY=          # https://aistudio.google.com — 메인 키
GEMINI_API_KEY_2=        # 백업 키 (선택, 키 로테이션용)
GEMINI_API_KEY_3=        # 백업 키 (선택)
GEMINI_API_KEY_4=        # 백업 키 (선택)

# AI APIs - 레거시/선택 (필요시)
ANTHROPIC_API_KEY=
FAL_KEY=
ELEVENLABS_API_KEY=      # 레거시 (Gemini TTS로 전환됨)
HF_TOKEN=                # 레거시 (FLUX.1 사용 시에만 필요)

# AWS S3 (데모에서는 로컬 파일시스템 사용 - 불필요)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=onceuponus-videos

# 로컬 파일 저장 경로 (기본값: /tmp/onceuponus)
LOCAL_STORAGE_DIR=/tmp/onceuponus

# Auth
NEXTAUTH_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# App
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000
